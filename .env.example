PORT=5000
NODE_ENV=development

# PostgreSQL + PostGIS
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_NAME=gis_ngocto
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/gis_ngocto
# DATABASE_LOGGING=true

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gis-ngocto

# Docker Compose (server): host port Redis nếu 6379 đã bị chiếm
# REDIS_PUBLISH_PORT=6380

# Auth — bắt buộc đổi JWT_SECRET trên production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# Tenant mặc định (UUID trong bảng tenants)
DEFAULT_TENANT_ID=a0000000-0000-4000-8000-000000000001

# Phường / ranh giới bản đồ
WARD_NAME=Ngọc Tố
WARD_CODE=ngoc-to
WARD_DISTRICT=Mỹ Xuyên
WARD_PROVINCE=Cần Thơ
WARD_DEFAULT_ZOOM=13
# WARD_CENTER_LAT=9.4466
# WARD_CENTER_LNG=105.9342

# GeoJSON: data/ward-boundaries/{WARD_BOUNDARY_DATASET}
WARD_BOUNDARY_DATASET=can-tho.geojson
WARD_BOUNDARY_MATCH_PROPERTY=ten_xa
WARD_BOUNDARY_MATCH_VALUE=Ngọc Tố
WARD_BOUNDARY_ADMIN_CODE=31723
WARD_BOUNDARY_ADMIN_CODE_PROPERTY=ma_xa
