# =========================
# Server
# =========================
PORT=4000
NODE_ENV=development

# =========================
# PostgreSQL + PostGIS
# =========================
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_NAME=gis_ngocto
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Full connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/gis_ngocto

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PUBLISH_PORT=6380

# =========================
# MinIO
# =========================
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gis-ngocto

# =========================
# Authentication
# =========================
# Production warning:
# - Không dùng giá trị mẫu bên dưới cho production.
# - NODE_ENV=production sẽ dừng boot nếu JWT_SECRET vẫn là default/empty.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=8h

# =========================
# Production safety notes
# =========================
# - Không dùng credential dev postgres/minioadmin cho production.
# - Không chạy seed demo Ngọc Tố trên database production mới.
# - RUN_SEED=true chỉ dành cho môi trường demo/local có chủ đích.

# =========================
# Default Tenant
# =========================
DEFAULT_TENANT_ID=a0000000-0000-4000-8000-000000000001

# =========================
# Administrative Boundary
# =========================
PROJECT_DISPLAY_NAME=GIS Ngọc Tố
PROJECT_API_DISPLAY_NAME=GIS Ngọc Tố API
PROJECT_DESCRIPTION=Hệ thống thông tin địa lý Xã Ngọc Tố, Cần Thơ

WARD_NAME=Ngọc Tố
WARD_LABEL=Xã Ngọc Tố
WARD_CODE=ngoc-to
WARD_DISTRICT=Mỹ Xuyên
WARD_PROVINCE=Cần Thơ
WARD_COUNTRY=Việt Nam

WARD_DEFAULT_ZOOM=12

WARD_CENTER_LAT=9.446632339808145
WARD_CENTER_LNG=105.93422393213204

# =========================
# Boundary GeoJSON
# =========================
WARD_BOUNDARY_DATASET=can-tho.geojson

WARD_BOUNDARY_MATCH_PROPERTY=ten_xa
WARD_BOUNDARY_MATCH_VALUE=Ngọc Tố

WARD_BOUNDARY_ADMIN_CODE=31723
WARD_BOUNDARY_ADMIN_CODE_PROPERTY=ma_xa
